<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Family Finance Hub | Tufazzal Mia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js"></script>
    <script src="https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; }
        .glass-card { background: rgba(255, 255, 255, 0.98); backdrop-filter: blur(10px); border: 1px solid rgba(226, 232, 240, 1); }
        input, select { transition: all 0.2s ease; outline: none; border: 1px solid #e2e8f0; }
        input:focus, select:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(165, 180, 252, 0.3); }
        .modal-overlay { background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(5px); }
        .month-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
        .month-group.active .month-content { max-height: 2000px; transition: max-height 0.5s ease-in; }
        .month-header svg { transition: transform 0.2s; }
        .month-group.active .month-header svg { transform: rotate(180deg); }
        main { flex: 1; }
        
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>
<body class="p-3 md:p-6">
    <main class="max-w-7xl mx-auto w-full">
        <!-- Header -->
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-slate-800 tracking-tight">Family Finance Hub</h1>
                <div class="flex items-center gap-2 mt-1">
                    <span id="syncIndicator" class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
                    <p id="userStatus" class="text-slate-500 text-xs font-medium uppercase tracking-wider">Connecting to Family Cloud...</p>
                </div>
            </div>
            <div class="flex items-center gap-3 w-full md:w-auto">
                <button onclick="downloadCSV()" class="flex-1 md:flex-none bg-slate-800 hover:bg-slate-900 text-white px-5 py-2.5 rounded-xl font-semibold flex items-center justify-center gap-2 transition-all shadow-lg shadow-slate-200">
                    <span>📊</span> Export CSV
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
            <!-- Expense Section -->
            <section class="glass-card rounded-2xl shadow-sm flex flex-col">
                <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-emerald-50/30">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <span class="text-emerald-600">💸</span> Family Expenses
                    </h2>
                    <span class="text-[10px] font-bold text-emerald-700 bg-emerald-100 px-2 py-1 rounded">GLOBAL VIEW</span>
                </div>
                
                <div class="p-5 space-y-4">
                    <div class="grid grid-cols-2 gap-2 bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <input type="date" id="expDate" class="rounded-lg p-2 text-sm">
                        <input type="text" id="expCategory" placeholder="Category (e.g. Market)" class="rounded-lg p-2 text-sm">
                        <input type="number" id="expAmount" placeholder="Amount" class="rounded-lg p-2 text-sm">
                        <input type="text" id="expNote" placeholder="Note" class="rounded-lg p-2 text-sm">
                        <button onclick="addExpense()" class="col-span-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition-all shadow-md">
                            Add Family Expense
                        </button>
                    </div>

                    <div class="pt-4 border-t border-slate-100">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Monthly Archives</h3>
                            <div class="text-right">
                                <p class="text-[10px] text-slate-400 uppercase">Grand Total</p>
                                <p class="text-lg font-bold text-slate-800" id="grandTotalExpense">0</p>
                            </div>
                        </div>
                        <div id="expenseArchive" class="space-y-3 max-h-[600px] overflow-y-auto pr-1"></div>
                    </div>
                </div>
            </section>

            <!-- Loan Section -->
            <section class="glass-card rounded-2xl shadow-sm flex flex-col">
                <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-orange-50/30">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <span class="text-orange-600">🤝</span> Loans & People
                    </h2>
                    <span class="text-[10px] font-bold text-orange-700 bg-orange-100 px-2 py-1 rounded">ALL CONTACTS</span>
                </div>

                <div class="p-5 space-y-4">
                    <div class="grid grid-cols-2 gap-2 bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <input type="date" id="loanDate" class="rounded-lg p-2 text-sm">
                        <input type="text" id="loanName" placeholder="Person's Name" class="rounded-lg p-2 text-sm">
                        <input type="tel" id="loanPhone" placeholder="Phone Number" class="rounded-lg p-2 text-sm">
                        <input type="number" id="loanAmount" placeholder="Amount" class="rounded-lg p-2 text-sm">
                        <select id="loanType" class="rounded-lg p-2 text-sm">
                            <option value="Given">Lent (Given)</option>
                            <option value="Taken">Borrowed (Taken)</option>
                        </select>
                        <input type="text" id="loanReason" placeholder="Reason" class="rounded-lg p-2 text-sm">
                        <button onclick="addLoan()" class="col-span-2 bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 rounded-xl transition-all shadow-md">
                            Save Loan Record
                        </button>
                    </div>

                    <div class="grid grid-cols-2 gap-3 mt-2">
                        <div class="bg-blue-50 p-3 rounded-xl border border-blue-100">
                            <p class="text-[10px] text-blue-600 font-bold uppercase">Total Lent</p>
                            <p class="text-xl font-bold text-blue-800" id="totalGiven">0</p>
                        </div>
                        <div class="bg-rose-50 p-3 rounded-xl border border-rose-100">
                            <p class="text-[10px] text-rose-600 font-bold uppercase">Total Borrowed</p>
                            <p class="text-xl font-bold text-rose-800" id="totalTaken">0</p>
                        </div>
                    </div>

                    <div class="overflow-x-auto mt-4 max-h-[400px] overflow-y-auto border border-slate-100 rounded-xl">
                        <table class="w-full text-left text-sm">
                            <thead class="bg-slate-50 sticky top-0">
                                <tr class="text-slate-500 border-b">
                                    <th class="p-4 font-semibold">Person</th>
                                    <th class="p-4 font-semibold">Phone</th>
                                    <th class="p-4 font-semibold text-right">Balance</th>
                                </tr>
                            </thead>
                            <tbody id="loanList" class="divide-y divide-slate-50"></tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-12 bg-slate-900 text-slate-400">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <div class="flex flex-col items-center gap-4">
                <div class="w-16 h-1 bg-indigo-500 rounded-full mb-2"></div>
                <div>
                    <p class="text-white font-bold text-2xl tracking-tight">Tufazzal Mia</p>
                    <p class="text-sm text-slate-500">Family Account Administrator</p>
                </div>
                <div class="flex flex-wrap justify-center gap-8 mt-4">
                    <a href="tel:01905150182" class="flex items-center gap-3 hover:text-white transition-colors group">
                        <span class="bg-slate-800 p-2.5 rounded-full text-sm group-hover:bg-slate-700">📞</span> 
                        <span class="font-semibold">01905150182</span>
                    </a>
                    <div class="flex items-center gap-3">
                        <span class="bg-slate-800 p-2.5 rounded-full text-sm">🌎</span> 
                        <span class="font-semibold">Public Family Hub</span>
                    </div>
                </div>
                <p class="text-[10px] uppercase tracking-[0.3em] mt-10 text-slate-600">Secure Family Finance Network • 2024</p>
            </div>
        </div>
    </footer>

    <!-- Person Ledger Modal -->
    <div id="ledgerModal" class="fixed inset-0 modal-overlay z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-3xl rounded-3xl shadow-2xl overflow-hidden animate-in fade-in slide-in-from-bottom-4 duration-300">
            <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <div>
                    <h3 class="text-2xl font-bold text-slate-800" id="ledgerPersonName">Name</h3>
                    <p class="text-slate-500 text-sm font-medium" id="ledgerPersonPhone">Phone</p>
                </div>
                <button onclick="closeLedger()" class="bg-white text-slate-400 hover:text-red-500 w-10 h-10 rounded-full flex items-center justify-center border border-slate-200 transition-all shadow-sm">✕</button>
            </div>
            <div class="p-6">
                <div id="ledgerSummary" class="mb-6 grid grid-cols-3 gap-4"></div>
                <div class="overflow-y-auto max-h-[50vh] border border-slate-100 rounded-2xl">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-slate-50 sticky top-0">
                            <tr class="text-slate-500 border-b">
                                <th class="p-4 font-semibold">Date</th>
                                <th class="p-4 font-semibold">Details</th>
                                <th class="p-4 font-semibold">Type</th>
                                <th class="p-4 font-semibold text-right">Amount</th>
                                <th class="p-4 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="ledgerItems" class="divide-y divide-slate-50"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-8 py-4 rounded-2xl text-sm opacity-0 transition-all pointer-events-none shadow-2xl z-[100] border border-slate-700"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, addDoc, onSnapshot, deleteDoc, doc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'family-finance-shared';

        let expenses = [];
        let loans = [];
        let currentUser = null;

        document.getElementById('expDate').valueAsDate = new Date();
        document.getElementById('loanDate').valueAsDate = new Date();

        // 1. Mandatory Auth Logic with await
        const initAuth = async () => {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            } catch (error) {
                console.error("Auth initialization failed", error);
                showToast("❌ Connection error");
            }
        };

        // 2. Auth State Observer
        onAuthStateChanged(auth, (user) => {
            currentUser = user;
            if (user) {
                document.getElementById('userStatus').innerText = "LIVE FAMILY CLOUD ACTIVE";
                document.getElementById('syncIndicator').className = "w-2 h-2 rounded-full bg-emerald-500";
                startSyncing();
            } else {
                document.getElementById('userStatus').innerText = "CONNECTING...";
                document.getElementById('syncIndicator').className = "w-2 h-2 rounded-full bg-amber-400 animate-pulse";
            }
        });

        // 3. Data Sync (Triggered only after Auth)
        function startSyncing() {
            const expCol = collection(db, 'artifacts', appId, 'public', 'data', 'family_expenses');
            const loanCol = collection(db, 'artifacts', appId, 'public', 'data', 'family_loans');

            onSnapshot(expCol, (snap) => {
                expenses = snap.docs.map(d => ({ id: d.id, ...d.data() }));
                renderExpenses();
            }, (err) => {
                console.error("Exp Snapshot error:", err);
                if (err.code === 'permission-denied') showToast("⚠️ Cloud access denied");
            });

            onSnapshot(loanCol, (snap) => {
                loans = snap.docs.map(d => ({ id: d.id, ...d.data() }));
                renderLoans();
                const modal = document.getElementById('ledgerModal');
                if (!modal.classList.contains('hidden')) {
                    openLedger(document.getElementById('ledgerPersonName').innerText);
                }
            }, (err) => {
                console.error("Loan Snapshot error:", err);
            });
        }

        initAuth();

        window.addExpense = async () => {
            if (!currentUser) return showToast("⏳ Waiting for connection...");
            const date = document.getElementById('expDate').value;
            const category = document.getElementById('expCategory').value;
            const amount = parseFloat(document.getElementById('expAmount').value);
            const note = document.getElementById('expNote').value;

            if (!date || !category || isNaN(amount)) return showToast("⚠️ Fill category and amount!");
            
            try {
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'family_expenses'), {
                    date, category, amount, note, createdAt: Date.now()
                });
                document.getElementById('expAmount').value = '';
                showToast("✅ Expense recorded");
            } catch (e) { showToast("❌ Save Error"); }
        };

        window.addLoan = async () => {
            if (!currentUser) return showToast("⏳ Waiting for connection...");
            const date = document.getElementById('loanDate').value;
            const name = document.getElementById('loanName').value.trim();
            const phone = document.getElementById('loanPhone').value.trim();
            const amount = parseFloat(document.getElementById('loanAmount').value);
            const type = document.getElementById('loanType').value;
            const reason = document.getElementById('loanReason').value;

            if (!name || isNaN(amount) || !date) return showToast("⚠️ Name and Amount required!");

            try {
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'family_loans'), {
                    date, name, phone, amount, type, reason, createdAt: Date.now()
                });
                document.getElementById('loanAmount').value = '';
                showToast("✅ Loan record saved");
            } catch (e) { showToast("❌ Save Error"); }
        };

        window.deleteItem = async (type, id, event) => {
            if (event) event.stopPropagation();
            if (!currentUser) return;
            const colName = type === 'expense' ? 'family_expenses' : 'family_loans';
            try {
                await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', colName, id));
                showToast("🗑️ Record deleted");
            } catch (e) { showToast("❌ Delete Error"); }
        };

        function renderExpenses() {
            const container = document.getElementById('expenseArchive');
            const totalDisplay = document.getElementById('grandTotalExpense');
            let grandTotal = 0;
            container.innerHTML = "";

            const groups = {};
            expenses.forEach(e => {
                const date = new Date(e.date);
                const key = `${date.toLocaleString('default', { month: 'long' })} ${date.getFullYear()}`;
                const sortKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
                if (!groups[key]) groups[key] = { items: [], total: 0, sortKey, label: key };
                groups[key].items.push(e);
                groups[key].total += e.amount;
                grandTotal += e.amount;
            });

            const sortedMonths = Object.keys(groups).sort((a,b) => groups[b].sortKey.localeCompare(groups[a].sortKey));
            
            sortedMonths.forEach(key => {
                const g = groups[key];
                const div = document.createElement('div');
                div.className = 'month-group border border-slate-200 rounded-2xl overflow-hidden bg-white shadow-sm';
                div.innerHTML = `
                    <div class="month-header p-5 flex justify-between items-center cursor-pointer hover:bg-slate-50 transition-colors" onclick="this.parentElement.classList.toggle('active')">
                        <div class="flex items-center gap-4">
                            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                            <span class="font-bold text-slate-800 text-base">${g.label}</span>
                        </div>
                        <div class="text-right">
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Month Total</p>
                            <p class="font-bold text-emerald-600 text-lg">${g.total.toLocaleString()}</p>
                        </div>
                    </div>
                    <div class="month-content bg-slate-50/40">
                        <div class="p-5 border-t border-slate-100">
                            <table class="w-full text-xs">
                                <tbody class="divide-y divide-slate-200">
                                    ${g.items.sort((a,b) => new Date(b.date) - new Date(a.date)).map(i => `
                                        <tr>
                                            <td class="py-3 text-slate-400 font-mono">${i.date}</td>
                                            <td class="py-3 font-semibold text-slate-700">${i.category}</td>
                                            <td class="py-3 text-right font-bold text-slate-900 text-sm">${i.amount.toLocaleString()}</td>
                                            <td class="py-3 text-center">
                                                <button onclick="deleteItem('expense', '${i.id}', event)" class="text-slate-300 hover:text-red-500 transition-colors px-2">✕</button>
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
                container.appendChild(div);
            });
            totalDisplay.innerText = grandTotal.toLocaleString();
        }

        function renderLoans() {
            const list = document.getElementById('loanList');
            const gDisp = document.getElementById('totalGiven');
            const tDisp = document.getElementById('totalTaken');
            let tGiven = 0, tTaken = 0;
            const people = {};

            loans.forEach(l => {
                l.type === 'Given' ? tGiven += l.amount : tTaken += l.amount;
                const k = l.name.toLowerCase().trim();
                if (!people[k]) people[k] = { name: l.name, phone: l.phone, net: 0 };
                people[k].net += (l.type === 'Given' ? l.amount : -l.amount);
                if (l.phone) people[k].phone = l.phone;
            });

            const unique = Object.values(people).sort((a,b) => a.name.localeCompare(b.name));
            list.innerHTML = unique.length ? '' : '<tr><td colspan="3" class="p-10 text-center text-slate-400">No records</td></tr>';

            unique.forEach(p => {
                list.innerHTML += `
                    <tr onclick="openLedger('${p.name}')" class="cursor-pointer hover:bg-indigo-50 transition-colors">
                        <td class="p-4 font-bold text-slate-800">${p.name}</td>
                        <td class="p-4 text-slate-500 text-xs">${p.phone || '-'}</td>
                        <td class="p-4 text-right font-bold ${p.net >= 0 ? 'text-emerald-600' : 'text-rose-600'}">
                            ${p.net >= 0 ? '+' : ''}${p.net.toLocaleString()}
                        </td>
                    </tr>
                `;
            });

            gDisp.innerText = tGiven.toLocaleString();
            tDisp.innerText = tTaken.toLocaleString();
        }

        window.openLedger = (name) => {
            const pLoans = loans.filter(l => l.name.toLowerCase().trim() === name.toLowerCase().trim()).sort((a,b) => new Date(b.date) - new Date(a.date));
            if (!pLoans.length) return closeLedger();

            const items = document.getElementById('ledgerItems');
            const sum = document.getElementById('ledgerSummary');
            document.getElementById('ledgerPersonName').innerText = name;
            document.getElementById('ledgerPersonPhone').innerText = pLoans[0].phone || "No phone number recorded";
            
            let g = 0, t = 0;
            items.innerHTML = "";
            pLoans.forEach(l => {
                l.type === 'Given' ? g += l.amount : t += l.amount;
                items.innerHTML += `
                    <tr class="hover:bg-slate-50">
                        <td class="p-4 text-slate-500 font-mono text-xs">${l.date}</td>
                        <td class="p-4 text-slate-700 font-medium">${l.reason || '-'}</td>
                        <td class="p-4"><span class="text-[9px] font-bold px-2 py-1 rounded-lg ${l.type === 'Given' ? 'bg-blue-100 text-blue-700' : 'bg-rose-100 text-rose-700'}">${l.type.toUpperCase()}</span></td>
                        <td class="p-4 text-right font-bold text-slate-800">${l.amount.toLocaleString()}</td>
                        <td class="p-4 text-center">
                            <button onclick="deleteItem('loan', '${l.id}', event)" class="text-slate-300 hover:text-red-500 transition-colors">✕</button>
                        </td>
                    </tr>
                `;
            });

            const net = g - t;
            sum.innerHTML = `
                <div class="bg-blue-50/50 p-4 rounded-2xl border border-blue-100 text-center">
                    <p class="text-[10px] text-blue-500 font-bold uppercase mb-1">Lent</p>
                    <p class="font-bold text-blue-900">${g.toLocaleString()}</p>
                </div>
                <div class="bg-rose-50/50 p-4 rounded-2xl border border-rose-100 text-center">
                    <p class="text-[10px] text-rose-500 font-bold uppercase mb-1">Borrowed</p>
                    <p class="font-bold text-rose-900">${t.toLocaleString()}</p>
                </div>
                <div class="${net >= 0 ? 'bg-emerald-50 border-emerald-100' : 'bg-amber-50 border-amber-100'} p-4 rounded-2xl border text-center">
                    <p class="text-[10px] ${net >= 0 ? 'text-emerald-500' : 'text-amber-600'} font-bold uppercase mb-1">Net Balance</p>
                    <p class="font-bold ${net >= 0 ? 'text-emerald-900' : 'text-amber-900'}">${Math.abs(net).toLocaleString()} ${net >= 0 ? '(Recievable)' : '(Payable)'}</p>
                </div>
            `;
            document.getElementById('ledgerModal').classList.remove('hidden');
        };

        window.closeLedger = () => document.getElementById('ledgerModal').classList.add('hidden');

        window.downloadCSV = () => {
            const clean = (val) => `"${String(val || '').replace(/"/g, '""')}"`;
            let csv = "--- FAMILY EXPENSES ---\nDate,Category,Amount,Note\n";
            expenses.forEach(e => csv += `${e.date},${clean(e.category)},${e.amount},${clean(e.note)}\n`);
            csv += "\n--- FAMILY LOANS ---\nDate,Name,Phone,Amount,Type,Reason\n";
            loans.forEach(l => csv += `${l.date},${clean(l.name)},${clean(l.phone)},${l.amount},${l.type},${clean(l.reason)}\n`);
            const blob = new Blob(["\uFEFF" + csv], { type: 'text/csv;charset=utf-8;' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `family_finance_backup_${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
        };

        function showToast(msg) {
            const t = document.getElementById('toast');
            t.innerText = msg;
            t.style.opacity = '1';
            t.style.transform = 'translate(-50%, 0)';
            setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translate(-50%, 10px)'; }, 3000);
        }
    </script>
</body>
</html>
